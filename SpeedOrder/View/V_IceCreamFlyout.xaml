<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeedOrder.View.V_IceCreamFlyout"
             Title="Flyout">
    <StackLayout BackgroundColor="Black">
        <ListView x:Name="MenuItemsListView" SeparatorVisibility="None" HasUnevenRows="true" ItemsSource="{Binding MenuItems}">
            <ListView.Header>
                <Grid BackgroundColor="#5F1890" RowDefinitions="Auto" Padding="0" Margin="0">
                    <Image Source="LONASPEEDORDER" Aspect="AspectFill" HeightRequest="190" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <ContentView>
                            <Grid ColumnDefinitions="Auto,*">
                                <Frame CornerRadius="100" HeightRequest="30" WidthRequest="30" Margin="5" BackgroundColor="White" VerticalOptions="Center" HorizontalOptions="Center">
                                    <Image Source="{Binding Icono}" Aspect="AspectFill" HeightRequest="40" WidthRequest="40" IsAnimationPlaying="True" />
                                </Frame>
                                <Label Grid.Column="1" Text="{Binding Title}" TextColor="White"  VerticalOptions="CenterAndExpand" FontSize="18" />
                            </Grid>
                        </ContentView>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackLayout>
</ContentPage>
