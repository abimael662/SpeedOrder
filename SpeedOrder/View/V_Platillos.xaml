<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeedOrder.View.V_Platillos"
             Title="Platillos">
    <StackLayout Padding="20">
        <ListView x:Name="ListaPlatillos" VerticalOptions="FillAndExpand" RowHeight="150" SeparatorVisibility="Default" SeparatorColor="Gray">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <ContentView>
                            <ScrollView>
                                <StackLayout Padding="10">
                                    <Frame BorderColor="Gray" CornerRadius="5" Padding="10" HeightRequest="100" WidthRequest="300" IsClippedToBounds="True" BackgroundColor="#FFDEED">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Image Source="{Binding TipoPlatillo}" x:Name="ImagenPlatillo" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" Grid.Column="0"/>

                                            <StackLayout Grid.Column="1" Padding="0">
                                                <Grid ColumnDefinitions="*,*">
                                                    <CheckBox Grid.Column="0"/>
                                                    <Label Text="Agotado" TextColor="Black" Margin="30,5,0,0"/>
                                                    <Label Text="{Binding Precio_Platillo, StringFormat='${0:F2}'}" TextColor="#000" HorizontalOptions="End" Grid.Column="1" FontSize="20"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="*,Auto" VerticalOptions="EndAndExpand">
                                                    <Frame Grid.Column="0" HasShadow="True" BackgroundColor="#CB53C1" Padding="0">
                                                        <Label Text="{Binding Nombre_Platillo}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="13" TextColor="White" Padding="0"/>
                                                    </Frame>
                                                    <Button Grid.Column="1" Text="+" BackgroundColor="#5F1890" x:Name="{Binding Nombre_PLatillo}" HorizontalOptions="End" VerticalOptions="Center" />
                                                </Grid>
                                            </StackLayout>
                                        </Grid>
                                    </Frame>
                                </StackLayout>
                            </ScrollView>
                        </ContentView>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Text="Generar Cuenta" x:Name="BtnI" BackgroundColor="#C44C89" Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" CornerRadius="15" />
    </StackLayout>
</ContentPage>