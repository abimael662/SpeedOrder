<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeedOrder.View.V_Desayunos"
             Title="Desayunos"
             Style="{DynamicResource PageTheme}">
    <StackLayout Padding="20">
        <ListView x:Name="ListaDesayunos" VerticalOptions="FillAndExpand" RowHeight="150" SeparatorVisibility="Default" SeparatorColor="Gray">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <ContentView>
                            <ScrollView>
                                <StackLayout Padding="10">
                                    <Frame BorderColor="Gray" CornerRadius="5" Padding="10" HeightRequest="100" WidthRequest="300" IsClippedToBounds="True" BackgroundColor="#FFDEED">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Image Source="Desayuno" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" Grid.Column="0"/>

                                            <StackLayout Grid.Column="1" Padding="0">
                                                <Grid ColumnDefinitions="*,*">
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding Disponible}"/>
                                                    <Label Text="Agotado" TextColor="Black" Margin="30,5,0,0"/>
                                                    <Label Text="{Binding Precio_Platillo, StringFormat='${0:F2}'}" TextColor="#000" HorizontalOptions="End" Grid.Column="1" FontSize="20"/>
                                                </Grid>
                                                <Grid>
                                                    <Frame HasShadow="True" BackgroundColor="#CB53C1">
                                                        <Label Text="{Binding Nombre_Platillo}" HorizontalOptions="Center" FontSize="18" TextColor="White" />
                                                    </Frame>
                                                </Grid>
                                            </StackLayout>
                                        </Grid>
                                    </Frame>
                                </StackLayout>
                            </ScrollView>
                        </ContentView>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Text="Agregar Desayuno" x:Name="BtnI" BackgroundColor="#C44C89" Style="{DynamicResource LabelTheme}" Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" CornerRadius="15" Clicked="Registrar_Clicked"/>
    </StackLayout>
</ContentPage>