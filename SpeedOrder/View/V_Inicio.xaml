    <Grid>
        <Image Source="Gato" x:Name="LogoInicio" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"/>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="1,0" EndPoint="1,1">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#000" Offset="0.7"/>
                    <GradientStop Color="#000" Offset="1"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>
        <Grid HeightRequest="200" RowSpacing="40" VerticalOptions="EndAndExpand">
            <StackLayout Spacing="10">
                <Grid>
                    <Frame Margin="4,-35,4,25" CornerRadius="30" HeightRequest="300" HasShadow="False" BackgroundColor="Transparent" HorizontalOptions="Start" VerticalOptions="Start">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <Label Grid.Row="0" LineHeight="1.5" FontAttributes="Bold" VerticalOptions="Start" HorizontalTextAlignment="Center" FontSize="{OnPlatform iOS='25', Android='20'}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span TextColor="White" x:Name="datos"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>
                    </Frame>
                </Grid>
            </StackLayout>
        </Grid>
    </Grid>
</ContentPage>