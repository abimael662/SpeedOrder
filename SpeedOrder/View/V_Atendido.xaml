<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeedOrder.View.V_Atendido"
             Title="Orden"
             Style="{DynamicResource PageTheme}">
    <ScrollView>
        <StackLayout Padding="30">
            <Frame Padding="10" CornerRadius="5" BackgroundColor="#5F1890">
                <Label Text="ORDEN A ATENDER" HorizontalOptions="CenterAndExpand" TextColor="White"/>
            </Frame>
            <Frame Padding="0" HasShadow="False" CornerRadius="5" BackgroundColor="Transparent">
                <Grid>
                    <Label x:Name="LblMesero" Text="Atendido por: " FontSize="18" TextColor="#C44C89" FontAttributes="Bold" Margin="2,5,0,0" VerticalOptions="Start"/>
                    <Entry x:Name="TxtMesero" Margin="0,20,0,20" FontSize="18" Style="{DynamicResource LabelTheme}" IsReadOnly="True" />
                </Grid>
            </Frame>

            <Frame Padding="0" HasShadow="False" CornerRadius="5" BackgroundColor="Transparent">
                <Grid>
                    <Label x:Name="LblCliente" Text="Nombre del Cliente:" FontSize="18" TextColor="#C44C89" FontAttributes="Bold" Margin="2,5,0,0" VerticalOptions="Start"/>
                    <Entry x:Name="TxtCliente" Margin="0,20,0,20" FontSize="18" Style="{DynamicResource LabelTheme}" IsReadOnly="True" />
                </Grid>
            </Frame>

            <Grid ColumnDefinitions="Auto,Auto" HorizontalOptions="CenterAndExpand">
                <Button Grid.Column="0" Text="Imprimir" x:Name="PDF" Clicked="PDF_Clicked" BackgroundColor="#C44C89" TextColor="White" CornerRadius="10" VerticalOptions="CenterAndExpand" />
                <Button Grid.Column="1" Text="QR" x:Name="QR"  Clicked="QR_Clicked" BackgroundColor="#C44C89" TextColor="White" CornerRadius="10" VerticalOptions="CenterAndExpand" />
            </Grid>

            <ListView x:Name="ListaPlatillos" VerticalOptions="FillAndExpand" RowHeight="150" SeparatorVisibility="Default" SeparatorColor="Gray" HasUnevenRows="True">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <ContentView>
                                <ScrollView>
                                    <StackLayout Padding="10">
                                        <Frame BorderColor="Gray" CornerRadius="5" Padding="10" BackgroundColor="#FFDEED">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Image Source="{Binding Photo}" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" HeightRequest="100" WidthRequest="100" Grid.Column="0"/>

                                                <StackLayout Grid.Column="1" Padding="10">
                                                    <Grid ColumnDefinitions="*,*" VerticalOptions="Center">
                                                        <Label Text="{Binding Precio_Platillo, StringFormat='${0:F2}'}" TextColor="#000" HorizontalOptions="End" FontSize="20" Grid.Column="1"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Frame Grid.Column="0" HasShadow="True" BackgroundColor="#CB53C1" Padding="0">
                                                            <Label Text="{Binding Nombre_Platillo}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="13" TextColor="White" Padding="0" />
                                                        </Frame>
                                                        <Button Grid.Column="1" Text="-" x:Name="TxtHola" BackgroundColor="#5F1890" HorizontalOptions="End" VerticalOptions="Center" Clicked="TxtCantidad_Clicked" CommandParameter="{Binding Id_Platillo}"  />
                                                    </Grid>
                                                </StackLayout>
                                            </Grid>
                                        </Frame>
                                    </StackLayout>
                                </ScrollView>
                            </ContentView>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Frame BackgroundColor="#5F1890" CornerRadius="50">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Text="SubTotal:" Grid.Column="0" Grid.Row="0" VerticalOptions="CenterAndExpand" TextColor="White" />
                    <Entry x:Name="TxtSubtotal" Grid.Column="1" Grid.Row="0" TextColor="White" IsReadOnly="True" />

                    <Label Text="Total:" Grid.Column="0"  Grid.Row="1" VerticalOptions="CenterAndExpand" TextColor="White" />
                    <Entry x:Name="TxtTotal" Grid.Column="1" Grid.Row="1" TextColor="White" IsReadOnly="True" />

                    <Label Text="Dar Propina del 15%:" Grid.ColumnSpan="2" Grid.Row="2" VerticalOptions="CenterAndExpand" TextColor="White" />
                    <CheckBox x:Name="Propina" Grid.Column="1" Grid.Row="2" HorizontalOptions="CenterAndExpand" Color="White" CheckedChanged="Propina_CheckedChanged"/>
                </Grid>
            </Frame>
        </StackLayout>
    </ScrollView>
</ContentPage>