<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             IconImageSource="Restaurante"
             x:Class="SpeedOrder.View.V_Mesas">
    <StackLayout Padding="10">

        <Frame BackgroundColor="#5F1890" CornerRadius="10" Padding="10">
            <Label Text="Organizador de Mesas" FontSize="Title" VerticalOptions="Center" HorizontalOptions="Center" TextColor="#FFF"/>
        </Frame>

        <StackLayout Orientation="Horizontal" Spacing="10" HorizontalOptions="Center">
            <Button Text="Crear Mesa" x:Name="RegisterTable"  BackgroundColor="#400B4B" TextColor="White" CornerRadius="10" Clicked="RegisterTable_Clicked" />
            <Button Text="Remover" x:Name="Remover" BackgroundColor="Red" TextColor="White" CornerRadius="10" Clicked="Remover_Clicked" />
        </StackLayout>

        <Grid x:Name="Canvas" HeightRequest="900" BackgroundColor="LightGray" Padding="0" Margin="0,0,0,10">
        </Grid>
    </StackLayout>
</ContentPage>