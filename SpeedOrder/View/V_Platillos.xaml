<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeedOrder.View.V_Platillos"
             Title="Platillos">
    <StackLayout Padding="20">
        <ListView x:Name="ListaPlatillos"
          VerticalOptions="FillAndExpand" 
          RowHeight="150" 
          SeparatorVisibility="Default" 
          SeparatorColor="Gray"
          HasUnevenRows="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Frame BorderColor="Gray" 
                       CornerRadius="5" 
                       Padding="10" 
                       BackgroundColor="#FFDEED">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Image Source="{Binding Photo}"
                               Aspect="AspectFill" 
                               HorizontalOptions="FillAndExpand" 
                               VerticalOptions="FillAndExpand"
                               HeightRequest="100"
                               WidthRequest="100"
                               Grid.Column="0"/>

                                <StackLayout Grid.Column="1" Padding="10">
                                    <Grid ColumnDefinitions="*,*" VerticalOptions="Center">
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Disponible}"/>
                                        <Label Text="Agotado" 
                                       TextColor="Black" 
                                       Margin="30,5,0,0"/>
                                        <Label Text="{Binding Precio_Platillo, StringFormat='${0:F2}'}" 
                                       TextColor="#000" 
                                       HorizontalOptions="End" 
                                       FontSize="20"
                                       Grid.Column="1"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Frame Grid.Column="0" 
                                       HasShadow="True" 
                                       BackgroundColor="#CB53C1" 
                                       Padding="0">
                                            <Label Text="{Binding Nombre_Platillo}" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center" 
                                           FontSize="13" 
                                           TextColor="White"
                                           Padding="0" />
                                        </Frame>
                                        <Button Grid.Column="1" 
                                        Text="+" 
                                        BackgroundColor="#5F1890" 
                                        Command="{Binding AgregarCommand}"
                                        HorizontalOptions="End" 
                                        VerticalOptions="Center"/>
                                    </Grid>
                                </StackLayout>
                            </Grid>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Text="Generar Cuenta" 
                x:Name="BtnI" 
                BackgroundColor="#C44C89" 
                HorizontalOptions="Center" 
                VerticalOptions="Center" 
                CornerRadius="15" />
    </StackLayout>
</ContentPage>