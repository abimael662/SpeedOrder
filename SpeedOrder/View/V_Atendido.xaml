<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpeedOrder.View.V_Atendido"
             Title="Orden">
    <ScrollView>
        <StackLayout Padding="30">
            <Frame Padding="10" CornerRadius="5" BackgroundColor="#5F1890">
                <Label Text="ORDEN A ATENDER" HorizontalOptions="CenterAndExpand" TextColor="White"/>
            </Frame>
            <Frame Padding="0" HasShadow="False" CornerRadius="5" BackgroundColor="Transparent">
                <Grid>
                    <Label x:Name="LblMesero" Text="Atendido por: " FontSize="18" TextColor="#C44C89" FontAttributes="Bold" Margin="2,5,0,0" VerticalOptions="Start"/>
                    <Entry x:Name="TxtMesero" Margin="0,20,0,20" FontSize="18"  TextColor="White" IsReadOnly="True" />
                </Grid>
            </Frame>

            <Frame Padding="0" HasShadow="False" CornerRadius="5" BackgroundColor="Transparent">
                <Grid>
                    <Label x:Name="LblCliente" Text="Nombre del Cliente:" FontSize="18" TextColor="#C44C89" FontAttributes="Bold" Margin="2,5,0,0" VerticalOptions="Start"/>
                    <Entry x:Name="TxtCliente" MaxLength="10" Margin="0,20,0,20" FontSize="18" />
                </Grid>
            </Frame>

            <Grid ColumnDefinitions="Auto,Auto" HorizontalOptions="CenterAndExpand">
                <Button Grid.Column="0" Text="Imprimir" x:Name="PDF" Clicked="PDF_Clicked" BackgroundColor="#C44C89" TextColor="White" CornerRadius="10" VerticalOptions="CenterAndExpand" />
                <Button Grid.Column="1" Text="QR" x:Name="QR"  Clicked="QR_Clicked" BackgroundColor="#C44C89" TextColor="White" CornerRadius="10" VerticalOptions="CenterAndExpand" />
            </Grid>

            <ListView x:Name="ListaPlatillos" VerticalOptions="FillAndExpand" RowHeight="150" SeparatorVisibility="Default" SeparatorColor="Gray"  ItemSelected="ListaPlatillos_ItemSelected">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <ContentView>
                                <ScrollView>
                                    <StackLayout Padding="10">
                                        <Frame BorderColor="Gray" CornerRadius="5" Padding="10" HeightRequest="100" WidthRequest="300" IsClippedToBounds="True" BackgroundColor="#FFDEED">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Image Source="{Binding Photo}" x:Name="ImgFoto" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand"/>

                                                <StackLayout Grid.Column="1" Padding="0">
                                                    <Grid ColumnDefinitions="*,*">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding Disponible}"/>
                                                        <Label Text="Agotado" TextColor="Black" Margin="30,5,0,0"/>
                                                        <Label Text="{Binding Precio_Platillo, StringFormat='${0:F2}'}" TextColor="#000" HorizontalOptions="End" Grid.Column="1" FontSize="20"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="EndAndExpand">
                                                        <Frame Grid.Column="0" HasShadow="True" BackgroundColor="#CB53C1" Padding="0">
                                                            <Label Text="{Binding Nombre_Platillo}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="13" TextColor="White" Padding="0"/>
                                                        </Frame>
                                                        <Button Grid.Column="1" 
                                                            Text="+" 
                                                            TextColor="White" 
                                                            BackgroundColor="#5F1890"  
                                                            Clicked="TxtCantidad_Clicked" 
                                                            CommandParameter="{Binding Id_Platillo}" 
                                                            HorizontalOptions="End" 
                                                            VerticalOptions="Center" />
                                                    </Grid>
                                                </StackLayout>
                                            </Grid>
                                        </Frame>
                                    </StackLayout>
                                </ScrollView>
                            </ContentView>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Frame Padding="0" HasShadow="True" BorderColor="Black">
                <Image x:Name="imagenQR"/>
            </Frame>
        </StackLayout>
    </ScrollView>
</ContentPage>